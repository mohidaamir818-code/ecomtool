NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gmail SMTP (use an App Password, not your regular Gmail password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your-email@gmail.com

ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
# Dropship / product fetch (OAuth). Do NOT use for Supplier Finder.
# Required for Dropship API (aliexpress.ds.product.get). Obtain via OAuth:
# https://api-sg.aliexpress.com/oauth/authorize?response_type=code&client_id=YOUR_APP_KEY&redirect_uri=YOUR_CALLBACK
ALIEXPRESS_ACCESS_TOKEN=
ALIEXPRESS_REFRESH_TOKEN=
ALIEXPRESS_API_KEY=

# Affiliate app (Supplier Finder only) — separate AliExpress Open Platform account
ALIEXPRESS_AFFILIATE_APP_KEY=
ALIEXPRESS_AFFILIATE_APP_SECRET=
EBAY_APP_ID=
EBAY_CERT_ID=
# eBay OAuth RuName string from Developer Portal (User Tokens), NOT the full URL
EBAY_RUNAME=YourName-YourApp-PRD-xxxxx

# Amazef platform product search API (base URL or full /api/products endpoint)
AMAZEF_API_URL=https://amazefcom-production.up.railway.app
AMAZEF_API_KEY=your-amazef-api-key

# Amazef listing intake + credential verify API (auto-listing)
AMAZEF_LISTING_API_URL=https://amazefcom-production.up.railway.app
AMAZEF_LISTING_SECRET=your-amazef-listing-secret

# Anthropic Claude (AI listing + VeRO checks)
ANTHROPIC_API_KEY=your-anthropic-api-key

# NVIDIA NIM image generation (text → image for listing photos, runs in parallel with listing AI)
NVIDIA_API_KEY=your-nvidia-nvapi-key
# Optional override (default: flux.2-klein-4b — ~2.5s, fast)
# NVIDIA_IMAGE_API_URL=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.2-klein-4b

# Public app URL (required for eBay OAuth callback + proxied description images in listings)
# Must match Auth Accepted URL host in eBay Developer Portal RuName settings
APP_URL=https://your-production-domain.com

# Hidden admin panel (not linked in the public UI)
ADMIN_PATH=/admin-hidden-portal-xyz-987
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=your-strong-admin-password
ALLOWED_IP=your.public.ip.address
ADMIN_SESSION_SECRET=your-long-random-secret
