{
  "manifest_version": 3,
  "name": "EcomTool HuntPro",
  "version": "1.0.0",
  "description": "Hunts hot eBay products for EcomTool using sold searches and Grabley history when available.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.ebay.com/*",
    "*://*.ebay.co.uk/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.ebay.com/*", "*://*.ebay.co.uk/*"],
      "js": ["content-scripts/ebay-scrape.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "https://*/*"
      ],
      "js": ["content-scripts/ecomtool-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "EcomTool HuntPro",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
